# ============================================================
#  비밀 설정 템플릿
#  이 파일을 복사해 application-secret.properties 로 만들고 실제 값을 채우세요.
#    (예) cp application-secret.properties.example application-secret.properties
#  실제 파일(application-secret.properties)은 .gitignore 처리되어 커밋되지 않습니다.
# ============================================================

# Oracle DB
spring.datasource.username=여기에_DB_계정
spring.datasource.password=여기에_DB_비밀번호

# Gmail SMTP (구글 계정 > 보안 > 앱 비밀번호 16자리)
spring.mail.username=your-gmail@gmail.com
spring.mail.password=구글_앱_비밀번호_16자리
