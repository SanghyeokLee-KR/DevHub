# GitHub Linguist — 언어 통계에서 서드파티/템플릿 자산 제외
# (저장소가 "JavaScript 프로젝트"로 잘못 표기되던 것 교정)

# 벤더 라이브러리 (jQuery · Bootstrap · Swiper · CodeMirror · RemixIcon 등)
src/main/resources/static/libs/**   linguist-vendored

# Bootstrap 템플릿 파생 스타일 (직접 디자인한 것이 아님)
src/main/resources/static/css/**    linguist-vendored
src/main/resources/static/scss/**   linguist-vendored

# 압축본 · 소스맵
*.min.js    linguist-vendored
*.min.css   linguist-vendored
*.map       linguist-generated

# 문서 · 다이어그램
docs/**       linguist-documentation
diagrams/**   linguist-documentation

# 템플릿 데모 페이지 · UI 컴포넌트 쇼케이스 모달
# (대부분 외부/템플릿 UI 코드를 보여주는 것이라 핵심 로직 아님)
src/main/resources/templates/fragments/**     linguist-vendored
src/main/resources/templates/services.html    linguist-vendored
src/main/resources/templates/services2.html   linguist-vendored
src/main/resources/templates/about.html       linguist-vendored
src/main/resources/templates/contact.html     linguist-vendored
